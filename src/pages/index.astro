---
import RootLayout from "../layouts/RootLayout.astro";
---

<RootLayout>
  <div class="max-w-3xl mx-auto p-8 space-y-6">
    <label class="input w-full">
      <svg
        class="h-[1em] opacity-50"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
      >
        <g
          stroke-linejoin="round"
          stroke-linecap="round"
          stroke-width="2.5"
          fill="none"
          stroke="currentColor"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </g>
      </svg>
      <input
        hx-get="/api/notes"
        hx-trigger="input delay:500ms, load"
        hx-target="#filteredNotes"
        type="search"
        name="q"
        class="grow"
        placeholder="Search by topics"
      />
      <kbd class="kbd kbd-md">Enter</kbd>
    </label>
    <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6" id="filteredNotes">
    </div>
  </div></RootLayout
>
